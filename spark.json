{
  "healthCheck": "/healthz",
  "resources": {
    "size": "medium"
  },
  "workers": [
    {
      "name": "arq-worker",
      "command": "sh -c \"PYTHONPATH=/app/ac-pulse arq app.workers.settings.WorkerSettings\"",
      "replicas": 1,
      "resources": {
        "size": "small"
      }
    }
  ],
  "webhooks": [
    {
      "path": "/admin/smoke-snowflake",
      "description": "Snowflake JWT smoke test — gated by X-Service-Key. Bypasses CF Access so other agents (and curl) can hit it via hooks.ac-spark.com."
    }
  ]
}
