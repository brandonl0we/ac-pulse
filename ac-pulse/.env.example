# Snowflake
SNOWFLAKE_BACKEND=direct
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_API_KEY=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_ROLE=

# Zapier MCP Snowflake POC backend (set SNOWFLAKE_BACKEND=zapier_mcp)
ZAPIER_MCP_URL=
ZAPIER_MCP_TOKEN=

# ActiveCampaign
AC_API_URL=https://brandontest.api-us1.com/api/3
AC_API_KEY=

# Redis
REDIS_URL=redis://localhost:6379/0

# Slack alerts
SLACK_WEBHOOK_URL=

# Operational
LIMIT_ACCOUNTS=
ENV=development
LOG_LEVEL=INFO

# Account ID mapping. ACCOUNT_ID_MAP_JSON takes precedence when set.
ACCOUNT_ID_MAP_PATH=./data/account_id_map.csv
ACCOUNT_ID_MAP_JSON=

# Runtime metadata
GIT_SHA=
